#
# mod-GrimTokenDailies Configuration
#

[worldserver]

########################################
# mod-GrimTokenDailies Settings
########################################

#
#   ModGrimTokenDailies.Enable
#       Description: Enable or disable the GrimTokenDailies module.
#       Default:     1 (Enabled)
#                    0 (Disabled)
#

ModGrimTokenDailies.Enable = 1

#
#   ModGrimTokenDailies.Announce.Enable
#       Description: Announce to players on login that the module is active.
#       Default:     1 (Enabled)
#                    0 (Disabled)
#

ModGrimTokenDailies.Announce.Enable = 1

#
#   ModGrimTokenDailies.TokenItemId
#       Description: Item entry for Grim Token (currency reward).
#       Default:     90000
#

ModGrimTokenDailies.TokenItemId = 90000

#
#   ModGrimTokenDailies.ClassicDutyItemId
#       Description: Item entry for the Classic dungeon duty mark
#                    (quest-required drop from classic final bosses).
#       Default:     90001
#

ModGrimTokenDailies.ClassicDutyItemId = 90001

#
#   ModGrimTokenDailies.TbcDutyItemId
#       Description: Item entry for the TBC dungeon duty mark
#                    (quest-required drop from Outland final bosses).
#       Default:     90002
#

ModGrimTokenDailies.TbcDutyItemId = 90002

#
#   ModGrimTokenDailies.QuestClassicId
#       Description: Quest entry for the Classic daily ("Doing Your Duty").
#       Default:     210010
#

ModGrimTokenDailies.QuestClassicId = 210010

#
#   ModGrimTokenDailies.QuestTbcId
#       Description: Quest entry for the TBC daily ("Service to Your Faction").
#       Default:     210011
#

ModGrimTokenDailies.QuestTbcId = 210011

#
#   ModGrimTokenDailies.NpcAllianceEntry
#       Description: Creature entry for the Alliance questgiver
#                    (Grim Token Envoy in Stormwind).
#       Default:     900100
#

ModGrimTokenDailies.NpcAllianceEntry = 900100

#
#   ModGrimTokenDailies.NpcHordeEntry
#       Description: Creature entry for the Horde questgiver
#                    (Grim Token Envoy in Orgrimmar).
#       Default:     900101
#

ModGrimTokenDailies.NpcHordeEntry = 900101

#
#   ModGrimTokenDailies.ClassicTokenReward
#       Description: Number of Grim Tokens awarded for the Classic daily.
#       Default:     1
#

ModGrimTokenDailies.ClassicTokenReward = 1

#
#   ModGrimTokenDailies.TbcTokenReward
#       Description: Number of Grim Tokens awarded for the TBC daily.
#       Default:     2
#

ModGrimTokenDailies.TbcTokenReward = 2

#
#   ModGrimTokenDailies.HeroicTokenReward
#       Description: Number of Grim Tokens awarded for WotLK Heroic
#                    Proof-of-Demise dailies.
#       Default:     5
#

ModGrimTokenDailies.HeroicTokenReward = 5
